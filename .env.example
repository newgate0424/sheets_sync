# Database
DATABASE_URL="mysql://user:password@localhost:3306/sheets_sync"

# Application
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
API_SECRET_KEY="your-secret-key-here"
NEXT_PUBLIC_API_SECRET_KEY="your-secret-key-here"

# Authentication
AUTH_USERNAME="admin"
AUTH_PASSWORD="your-password-here"

# Google API (ไม่จำเป็นถ้าใช้ไฟล์ credentials.json)
# GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----"

# หมายเหตุ: ระบบจะอ่านจากไฟล์ credentials.json ที่ root ของโปรเจคก่อน
# ถ้าไม่มีไฟล์ credentials.json จึงจะใช้ค่าจาก GOOGLE_SERVICE_ACCOUNT_EMAIL และ GOOGLE_PRIVATE_KEY

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
API_SECRET_KEY="your-secret-key-for-cron-jobs"
